PARSER_ENV=dev
LOG_LEVEL=INFO

# OCR engines toggles (BUILD MODE)
ENABLE_TESSERACT=1
ENABLE_EASYOCR=1
ENABLE_PADDLEOCR=0

# System paths (optional)
TESSERACT_CMD=

# --- Google Cloud Vision (Document Text Detection) ---
# 1. Enable "Cloud Vision API" on your GCP project and create a service account key (JSON).
# 2. Copy configs/google_vision_service_account.sample.json to configs/google_vision_service_account.json
#    and replace placeholders with values from the downloaded key.
# 3. Point this variable at that file (absolute path works too). Loaded via python-dotenv in app.cli.
GOOGLE_APPLICATION_CREDENTIALS=configs/google_vision_service_account.json
